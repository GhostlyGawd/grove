{
  "name": "@swarm/ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./tailwind-preset": {
      "types": "./src/tailwind-preset.ts",
      "default": "./src/tailwind-preset.ts"
    },
    "./tokens.css": "./src/tokens.css",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/react/index.ts --outdir ./dist --target browser --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@swarm/db": "workspace:*",
    "lucide-react": "^1.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.17"
  }
}
